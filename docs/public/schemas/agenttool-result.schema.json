    },
    "invocation_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "is_error": {
      "type": "boolean"
    },
    "content": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
