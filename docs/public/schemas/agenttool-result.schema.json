      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "telemetry_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "persistence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
