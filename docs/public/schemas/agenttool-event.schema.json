{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Tool event",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "source",
    "time"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "time": {
      "type": "string"
    },
    "invocation_id": {
      "type": "string"
    },
    "tool_id": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    },
    "trace_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
